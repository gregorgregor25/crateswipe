# Server
NODE_ENV=development
# For local dev use 127.0.0.1. For VPS deployment bind to 0.0.0.0 so phones
# can reach the API over Tailscale (Tailscale is the only route in — VPS
# firewall must block port 3010 from the public internet).
HOST=127.0.0.1
PORT=3010
LOG_LEVEL=info

# SQLite DB file (created on first run)
DB_PATH=/home/gregor/.crateswipe/db.sqlite

# yt-dlp audio cache on the VPS
MUSIC_CACHE_PATH=/home/gregor/music/crateswipe

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=change-me

# External APIs
LASTFM_API_KEY=
LASTFM_API_SECRET=
GETSONGBPM_API_KEY=
